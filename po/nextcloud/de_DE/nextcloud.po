#: nextcloud.php templates/CRM/Contact/Page/View/Summary/nextcloud.tpl
msgid "Nextcloud"
msgstr "Nextcloud"

#: settings/nextcloud.setting.php
msgid "NextCloud External URL"
msgstr "NextCloud Externe URL"

#: settings/nextcloud.setting.php
msgid "Points to the nextcloud webinterface."
msgstr "Zeigt auf das Nextcloud-Webinterface"

#: settings/nextcloud.setting.php
msgid "NextCloud Internal URL"
msgstr "NextCloud Interne URL"

#: settings/nextcloud.setting.php
msgid ""
"Used for the API connection. Can be different from the external url, for "
"example behind a proxy, or when docker is used."
msgstr ""
"Wird für API-Verbindungen benutzt. Kann abweichend sein von der Externen "
"URL, z.B. hinter einem Proxy oder wenn Docker in Benutzung ist."

#: settings/nextcloud.setting.php
msgid "NextCloud User"
msgstr "NextCloud User"

#: settings/nextcloud.setting.php
msgid "Used for the API credentials."
msgstr "Benutzt für API Credentials."

#: settings/nextcloud.setting.php
msgid "NextCloud Password"
msgstr "NextCloud Passwort"

#: settings/nextcloud.setting.php
msgid "Used for the API credentials"
msgstr "Benutzt für API Credentials."

#: settings/nextcloud.setting.php
msgid "CiviCRM file directory"
msgstr "CiviCRM Dateiverzeichnis"

#: settings/nextcloud.setting.php
msgid ""
"Directory where the files are stored, every entity type has its own "
"subdirectory."
msgstr ""
"Verzeichnis wo die Dateien abgelegt werden, jede Entität hat ihr eigenes "
"Unterverzeichnis."

#: settings/nextcloud.setting.php
msgid "Enabled entities"
msgstr "Aktivierte Entitäten"

#: settings/nextcloud.setting.php
msgid "Check the entities that you want to enable in the interface"
msgstr "Prüfe die Entitäten, die im Interface aktiviert sein sollen"

