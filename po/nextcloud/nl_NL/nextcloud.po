#: nextcloud.php templates/CRM/Contact/Page/View/Summary/nextcloud.tpl
msgid "Nextcloud"
msgstr "Nextcloud"

#: settings/nextcloud.setting.php
msgid "NextCloud External URL"
msgstr "Nextcloud Externe URL"

#: settings/nextcloud.setting.php
msgid "Points to the nextcloud webinterface."
msgstr "Verwijst naar de webinterface van Nextcloud."

#: settings/nextcloud.setting.php
msgid "NextCloud Internal URL"
msgstr "Nextcloud Interne URL"

#: settings/nextcloud.setting.php
msgid ""
"Used for the API connection. Can be different from the external url, for "
"example behind a proxy, or when docker is used."
msgstr ""
"Wordt gebruikt voor de API-verbinding. Kan afwijken van de externe URL, "
"bijvoorbeeld wanneer er een proxy tussen zit of wanneer Docker wordt "
"gebruikt."

#: settings/nextcloud.setting.php
msgid "NextCloud User"
msgstr "Nextcloud Gebruiker"

#: settings/nextcloud.setting.php
msgid "Used for the API credentials."
msgstr "Gebruikt voor API referenties"

#: settings/nextcloud.setting.php
msgid "NextCloud Password"
msgstr "Nextcloud Wachtwoord"

#: settings/nextcloud.setting.php
msgid "Used for the API credentials"
msgstr "Gebruikt voor de API referenties"

#: settings/nextcloud.setting.php
msgid "CiviCRM file directory"
msgstr "CiviCRM-bestandsmap"

#: settings/nextcloud.setting.php
msgid ""
"Directory where the files are stored, every entity type has its own "
"subdirectory."
msgstr ""
"Map waarin de bestanden zijn opgeslagen; elk entiteitstype heeft zijn eigen "
"submap."

#: settings/nextcloud.setting.php
msgid "Enabled entities"
msgstr "Ingeschakelde Entiteiten"

#: settings/nextcloud.setting.php
