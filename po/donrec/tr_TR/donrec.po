msgstr "Tamamlanmamış bir çalışma bulundu"

#: templates/CRM/Donrec/Form/Task/remaining_snapshot.tpl
msgid "You have an unfinished run, do you want to continue with it?"
msgstr "Tamamlanmamış bir çalışmanız var. Sürdürülmesini ister misiniz?"

#: templates/CRM/Donrec/Form/Task/remaining_snapshot.tpl
msgid "Otherwise it <b>will be deleted</b>!"
msgstr "Yoksa <b>silinecek</b>!"

#: templates/CRM/Donrec/Form/Task/remaining_snapshot.tpl
msgid "An interrupted run has been detected. Do you want to continue with it?"
msgstr "Kesintiye uğramış bir çalışma bulundu. Sürdürülmesini ister misiniz?"

#: templates/CRM/Donrec/Form/Task/remaining_snapshot.tpl
msgid "Otherwise the selection <b>will be deleted</b>!"
msgstr "Yoksa seçim <b>silinecek</b>!"

#: templates/CRM/Donrec/Form/Task/remaining_snapshot.tpl
msgid ""
"<b>Caution!</b> Some receipts have already been created. If you do not "
"continue with this run, you should probably delete them manually."
msgstr ""
"<b>Dikkat!</b> Bazı alındılar zaten oluşturulmuş. Bu çalışmayı "
"sürdürmezseniz, bunları el ile silmeniz gerekebilir."

