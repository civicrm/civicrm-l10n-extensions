#: Civi/Firewall/Firewall.php
msgid "Session expired. Please reload and try again."
msgstr ""
"Relace vypršela. Prosím, znovu aktualizujte stránku a zkuste to znova."

#: Civi/Firewall/Firewall.php
msgid "Session invalid. Please reload and try again."
msgstr ""
"Relace je neplatná. Prosím, znovu aktualizujte stránku a zkuste to znova."

#: Civi/Firewall/Firewall.php
msgid "Blocked"
msgstr "Zablokováno"

#: schema/FirewallIpaddress.entityType.php
msgid "Firewall Ipaddress"
msgstr "IP adresa firewallu"

#: schema/FirewallIpaddress.entityType.php
msgid "Firewall Ipaddresses"
msgstr "IP adresy firewallu"

#: schema/FirewallIpaddress.entityType.php
msgid "IP addresses logged by firewall"
msgstr ""

#: schema/FirewallIpaddress.entityType.php
msgid "ID"
msgstr "ID"

#: schema/FirewallIpaddress.entityType.php
msgid "Unique FirewallIpaddress ID"
msgstr "Unikátní ID FirewallIpaddress"

#: schema/FirewallIpaddress.entityType.php
msgid "IP Address"
msgstr "IP adresa"

#: schema/FirewallIpaddress.entityType.php
msgid "IP address used"
msgstr "Použitá IP adresa"

#: schema/FirewallIpaddress.entityType.php
msgid "Access Date"
msgstr "Datum přístupu"

#: schema/FirewallIpaddress.entityType.php
msgid "When the IP address accessed"
msgstr "Kdy bylo přistupováno na IP adresu"

#: schema/FirewallIpaddress.entityType.php
msgid "Event Type"
msgstr "Typ události"

#: schema/FirewallIpaddress.entityType.php
msgid "The type of event that triggered this log"
msgstr "Druh události, který vyvolal tento log záznam"

#: schema/FirewallIpaddress.entityType.php
msgid "Source"
msgstr "Zdroj"

#: schema/FirewallIpaddress.entityType.php
msgid "Origin of this access request"
msgstr "Původ tohoto požadavku na přístup"

#: settings/firewall.setting.php
msgid "Is server behind reverse proxy?"
msgstr "Je server za reverzní proxy?"

#: settings/firewall.setting.php
msgid ""
"If yes, try to retrieve the IP address of the actual client instead of using"
" REMOTE_ADDR header"
msgstr ""
"Pokud ano, zkuste získat IP adresu skutečného klienta místo použití hlavičky"
" REMOTE_ADDR"

#: settings/firewall.setting.php
msgid "Firewall Reverse Proxy Header"
msgstr "Firewall reverzní proxy hlavička"

#: settings/firewall.setting.php
msgid "Reverse Proxy Header (default HTTP_X_FORWARDED_FOR)"
msgstr "Hlavička reverzního proxy serveru (výchozí je HTTP_X_FORWARDED_FOR)"

#: settings/firewall.setting.php
msgid "List of reverse proxy IP addresses"
msgstr "Seznam IP adres reverzní proxy"

#: settings/firewall.setting.php
msgid ""
"List of reverse proxy IP addresses that may be seen by your server. Used to "
"help identify client IP address"
msgstr ""
"Seznam IP adres reverzní proxy, které můžete vidět na vašem serveru. Používá"
" se k identifikaci IP adresy klienta"

#: settings/firewall.setting.php
msgid "List of IP addresses to always allow"
msgstr "Seznam IP adres, které vždy povolit"

#: settings/firewall.setting.php
msgid ""
"List of IP addresses that will never be blocked. For IPv4 can include "
"wildcards eg. 192.168.*"
msgstr ""
"Seznam IP adres, které nikdy nebudou blokovány. Pro IPv4 adresy lze použít "
"zástupné znaky – např. 192.168.*"

#: settings/firewall.setting.php
msgid "List of IP addresses to block"
msgstr "Seznam IP adres k blokaci"

#: settings/firewall.setting.php
msgid ""
"List of IP addresses that will always be blocked. For IPv4 can include "
"wildcards eg. 192.168.*"
msgstr ""
"Seznam IP adres, které budou vždy blokovány. Pro IPv4 adresy lze použít "
"zástupné znaky – např. 192.168.*"

#: settings/firewall.setting.php
msgid "Threshold of card decline events before an IP Address is blocked"
msgstr ""

#: settings/firewall.setting.php
msgid ""
"How many times should an IP Address be able to trigger a card decline before"
" being blocked"
msgstr ""

#: settings/firewall.setting.php
msgid "Threshold of how many invalid CSRF Failures"
msgstr ""

#: settings/firewall.setting.php
msgid ""
"How many times should an IP Address be able to submit with a bad CSRF value "
"before being blocked"
msgstr ""

#: settings/firewall.setting.php
msgid "Threshold of Form protection events before an IP Address is blocked"
msgstr ""

#: settings/firewall.setting.php
msgid ""
"How many times should an IP Address be able to trigger form protection event"
" before being blocked"
msgstr ""

#: settings/firewall.setting.php
msgid "Threshold of card fraud events before an IP Address is blocked"
msgstr ""

#: settings/firewall.setting.php
msgid ""
"How many times should an IP Address be able to trigger a card fraud before "
"being blocked"
msgstr ""
