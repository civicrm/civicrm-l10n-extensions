msgstr "Vous n'êtes pas autorisé à émettre des remboursements."

#: CRM/Mjwshared/Form/PaymentRefund.php
msgid "Refund payment"
msgstr ""

#: CRM/Mjwshared/Form/PaymentRefund.php
msgid ""
"There is more than one payment for this Contribution. You need to select a "
"specific payment to refund."
msgstr ""
"Il y a plus d'un paiement pour cette contribution. Vous devez sélectionner "
"un paiement spécifique à rembourser."

#: CRM/Mjwshared/Form/PaymentRefund.php
msgid ""
"No Payment found. Make sure you specified a valid Payment or Contribution."
msgstr ""
"Aucun paiement trouvé. Assurez-vous d'avoir spécifié un paiement ou une "
"contribution valide."

#: CRM/Mjwshared/Form/PaymentRefund.php
msgid "Contribution / Payment does not match"
msgstr ""

#: CRM/Mjwshared/Form/PaymentRefund.php
msgid "Do you want to cancel these registrations when you refund the payment?"
msgstr ""
"Voulez-vous annuler ces inscriptions lorsque vous remboursez le paiement ?"

#: CRM/Mjwshared/Form/PaymentRefund.php
msgid "Do you want to cancel these memberships when you refund the payment?"
msgstr ""
"Voulez-vous annuler ces adhésions lorsque vous remboursez le paiement ?"

#: CRM/Mjwshared/Form/PaymentRefund.php
msgid "Amount to Refund"
msgstr "Montant à rembourser"

#: CRM/Mjwshared/Form/PaymentRefund.php
msgid "Process Refund"
msgstr "Traiter le remboursement"

#: CRM/Mjwshared/Form/PaymentRefund.php
msgid "Cancel"
msgstr "Annuler"

#: CRM/Mjwshared/Form/PaymentRefund.php
msgid "Cannot refund more than the original amount"
msgstr ""

#: CRM/Mjwshared/Form/PaymentRefund.php
